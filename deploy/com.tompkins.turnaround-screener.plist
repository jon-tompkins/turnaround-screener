<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tompkins.turnaround-screener</string>

    <!-- Run scripts/morning.sh at 9am local time, every day.
         macOS launchd uses the Mac's TZ. If you want strict Pacific
         regardless of where the Mac is, set TZ in EnvironmentVariables. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TZ</key>
        <string>America/Los_Angeles</string>
        <!-- Add PATH so git/gh resolve; adjust if your install is elsewhere -->
        <key>PATH</key>
        <string>/Users/jonathantompkins/.npm-global/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_ROOT__/scripts/morning.sh</string>
    </array>

    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/data/logs/launchd.out</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/data/logs/launchd.err</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
