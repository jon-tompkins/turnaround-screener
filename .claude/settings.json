{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebSearch",
      "WebFetch",
      "Bash(.venv/bin/python scripts/merge_analyses.py)",
      "Bash(.venv/bin/python scripts/merge_analyses.py:*)",
      "Bash(.venv/bin/python scripts/run_daily.py:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(cat data/pending/*)",
      "Bash(cat data/analyzed/*)",
      "Bash(mkdir -p data/analyzed/*)",
      "Bash(mkdir -p data/research)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
