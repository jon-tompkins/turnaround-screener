# Required
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional - improves enrichment quality
# FMP_API_KEY: Financial Modeling Prep, $14-29/mo
# NEWSAPI_KEY: NewsAPI.org, free tier 100/day
FMP_API_KEY=
NEWSAPI_KEY=

# Optional - notifications
# SLACK_WEBHOOK_URL: full https://hooks.slack.com/... URL for daily report push
# TELEGRAM_*: alternative to Slack
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading system webhook — push structured JSON after each daily run
# Set to your trading system's endpoint URL + bearer token
TRADING_WEBHOOK_URL=https://www.myjunto.xyz/api/webhooks/signal
TRADING_WEBHOOK_TOKEN=

# Model selection (defaults to sonnet for cost; opus for retrospectives)
CLAUDE_ANALYST_MODEL=claude-sonnet-4-6
CLAUDE_RETROSPECTIVE_MODEL=claude-opus-4-7
